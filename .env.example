# ============================================
# SkillMark Environment Configuration
# ============================================

# --- App ---
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:8000/api

# --- AI Agents ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=your-google-ai-key
OPENAI_API_KEY=sk-...

# --- OAuth (configure in Supabase Dashboard) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...

# --- Storage ---
STORAGE_PROVIDER=supabase       # supabase | google_drive
GOOGLE_DRIVE_CREDENTIALS=       # path to service account JSON

# --- Email ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@skillmark.dev

# --- License (Portable mode only) ---
SKILLMARK_LICENSE_KEY=

# --- Docker (portable mode only) ---
POSTGRES_PASSWORD=postgres
FRONTEND_PORT=3000

# --- Misc ---
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000
